# ==========================================================================
# StayEase Backend — Environment Variables
# Copy this file to ".env" and fill in real values. NEVER commit the real .env
# ==========================================================================

# --- Server ---
SERVER_PORT=8080

# --- MongoDB ---
# Local:   mongodb://localhost:27017/stayease
# Atlas:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/stayease?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/stayease

# --- JWT (generate a long random string, >= 64 chars) ---
JWT_SECRET=replace-with-a-64-plus-character-random-secret-string
JWT_ACCESS_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# --- CORS (frontend origins, comma separated) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Email (SMTP) notifications ---
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@stayease.com

# --- Twilio SMS notifications ---
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+10000000000

# --- Seed demo data on startup ---
SEED_ENABLED=true
